# Required
STEAM_API_KEY=your_steam_api_key_here

# Server
PORT=3000
NODE_ENV=development

# Steam query filters
APP_ID=4465480
TARGET_MAP=de_dust2
ALLOWED_COUNTRIES=PL,DE
MIN_SLOTS=8
MAX_SLOTS=10
STEAM_LIMIT=500

# Refresh behavior
AUTO_REFRESH_ENABLED=true
REFRESH_INTERVAL_MS=300000
WAIT_FOR_INITIAL_REFRESH=false

# Worker / cache tuning
WORKER_CONCURRENCY=20
COUNTRY_CACHE_TTL_MS=3600000
MAX_STALE_MS=900000
SHUTDOWN_REFRESH_WAIT_MS=3000

# GeoIP provider
GEOIP_URL=http://ip-api.com/json

# Optional protection for POST /api/refresh
REFRESH_TOKEN=

# Optional snapshot persistence
SNAPSHOT_CACHE_FILE=./data/cache-snapshot.json
RESTORE_SNAPSHOT_ON_STARTUP=true
PERSIST_SNAPSHOT_ON_REFRESH=true
